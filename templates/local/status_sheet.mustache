{{!
    @template format_smartcards/local/status_sheet

    Body of the status sheet (core/modal) opened when a student taps a card
    that needs more room than the icon badges alone can show: an
    availability reason/date, a pending completion (manual toggle button or
    automatic criteria list), and/or a "Display description" intro.

    Example context (json):
    {
        "hasbadgelabel": true,
        "badgelabel": "Restricted",
        "hasreason": true,
        "reason": "Not available unless you complete Forum introduction",
        "statusreasonlabel": "Reason",
        "hasduedate": true,
        "duedateformatted": "3 August 2026",
        "statusduelabel": "Due date",
        "hascompletion": true,
        "statuscompletionlabel": "Completion",
        "ismanual": true,
        "isautomatic": false,
        "iscompletioncomplete": false,
        "cmid": 5,
        "cantoggle": true,
        "markcompletelabel": "Mark as done",
        "markincompletelabel": "Mark as not done",
        "criteria": [
            {"description": "Receive a grade", "statuscomplete": false, "statuscompletefail": false, "statusincomplete": true, "istrackeduser": true}
        ],
        "hasdescription": true,
        "statusdescriptionlabel": "Description",
        "description": "<p>Read chapters 1-3 before attempting this quiz.</p>",
        "hasurl": true,
        "url": "#",
        "accessactivitylabel": "Access activity"
    }
}}
<div class="sc-sheet" data-region="smartcards-sheet" data-cmid="{{cmid}}">
    {{#hasbadgelabel}}<p class="sc-sheet-badgelabel">{{badgelabel}}</p>{{/hasbadgelabel}}
    {{#hasreason}}
        <div class="sc-sheet-row">
            <span class="sc-sheet-label">{{statusreasonlabel}}</span>
            {{! reason is core-generated availability markup (core_availability info::format_info),
                the same trusted content core itself renders with a triple-brace tag in
                course format templates local content cm availability.mustache — never raw user input. }}
            <div class="sc-sheet-reason">{{{reason}}}</div>
        </div>
    {{/hasreason}}
    {{#hasduedate}}
        <div class="sc-sheet-row">
            <span class="sc-sheet-label">{{statusduelabel}}</span>
            <span class="sc-sheet-value">{{duedateformatted}}</span>
        </div>
    {{/hasduedate}}
    {{#hascompletion}}
        <div class="sc-sheet-row">
            <span class="sc-sheet-label">{{statuscompletionlabel}}</span>
            {{#ismanual}}
                {{#cantoggle}}
                <button
                    type="button"
                    class="btn btn-outline-primary sc-sheet-toggle"
                    data-region="smartcards-sheet-toggle"
                    data-cmid="{{cmid}}"
                    data-iscompletioncomplete="{{#iscompletioncomplete}}1{{/iscompletioncomplete}}{{^iscompletioncomplete}}0{{/iscompletioncomplete}}"
                    data-markcompletelabel="{{markcompletelabel}}"
                    data-markincompletelabel="{{markincompletelabel}}"
                >{{#iscompletioncomplete}}{{markincompletelabel}}{{/iscompletioncomplete}}{{^iscompletioncomplete}}{{markcompletelabel}}{{/iscompletioncomplete}}</button>
                {{/cantoggle}}
                {{^cantoggle}}
                <span class="sc-sheet-value">
                    {{#iscompletioncomplete}}{{markincompletelabel}}{{/iscompletioncomplete}}{{^iscompletioncomplete}}{{markcompletelabel}}{{/iscompletioncomplete}}
                </span>
                {{/cantoggle}}
            {{/ismanual}}
            {{#isautomatic}}
                {{! Reuses core's own core_course/completion_automatic template — the same
                    "Done: View" / "To do: Receive a grade" pill the course page shows —
                    instead of redrawing an equivalent status indicator. }}
                <div class="sc-sheet-criteria" role="list">
                    {{#criteria}}
                        {{> core_course/completion_automatic }}
                    {{/criteria}}
                </div>
            {{/isautomatic}}
        </div>
    {{/hascompletion}}
    {{#hasdescription}}
        <div class="sc-sheet-row">
            <span class="sc-sheet-label">{{statusdescriptionlabel}}</span>
            {{! description is core-generated via format_module_intro() (format_text under the
                hood), the same trusted rendering core itself uses for activity intros — not raw
                user input rendered unescaped. }}
            <div class="sc-sheet-description">{{{description}}}</div>
        </div>
    {{/hasdescription}}
    {{#hasurl}}
        <a href="{{url}}" class="btn btn-primary sc-sheet-access">{{accessactivitylabel}}</a>
    {{/hasurl}}
</div>
