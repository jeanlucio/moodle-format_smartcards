{{!
    @template format_smartcards/local/status_sheet

    Body of the status sheet (core/modal) opened when a student taps a card
    that carries a badge. Shows the badge label, the reason text already
    computed by core availability, an optional due date, and an "Access"
    link only when the activity is actually reachable.

    Example context (json):
    {
        "badgelabel": "Restricted",
        "hasreason": true,
        "reason": "Not available unless you complete Forum introduction",
        "statusreasonlabel": "Reason",
        "hasduedate": true,
        "duedateformatted": "3 August 2026",
        "statusduelabel": "Due date",
        "hasurl": false,
        "url": "#",
        "accessactivitylabel": "Access activity"
    }
}}
<div class="sc-sheet">
    <p class="sc-sheet-badgelabel">{{badgelabel}}</p>
    {{#hasreason}}
        <div class="sc-sheet-row">
            <span class="sc-sheet-label">{{statusreasonlabel}}</span>
            {{! reason is core-generated availability markup (\core_availability\info::format_info()),
                the same trusted content core itself renders with {{{text}}} in
                course/format/templates/local/content/cm/availability.mustache — never raw user input. }}
            <div class="sc-sheet-reason">{{{reason}}}</div>
        </div>
    {{/hasreason}}
    {{#hasduedate}}
        <div class="sc-sheet-row">
            <span class="sc-sheet-label">{{statusduelabel}}</span>
            <span class="sc-sheet-value">{{duedateformatted}}</span>
        </div>
    {{/hasduedate}}
    {{#hasurl}}
        <a href="{{url}}" class="btn btn-primary sc-sheet-access">{{accessactivitylabel}}</a>
    {{/hasurl}}
</div>
