{{!
    @template format_smartcards/local/cm_trail

    One section's card trail, for navstyle = 'trail'. Same cards as cm_grid.mustache
    (cm_button.mustache, unchanged), laid out as a single winding column instead of a
    wrapping grid — the zigzag itself is pure CSS (styles.css .sc-trail, alternating
    margin-inline-start per :nth-child), so DOM order always matches course order:
    tab order and screen-reader order both stay correct, unlike a CSS `order`-based
    reshuffle would.

    Example context (json):
    {
        "hascards": true,
        "cards": [
            {
                "cmid": 5,
                "name": "Quiz 1",
                "iconurl": "#",
                "modtypelabel": "Quiz",
                "url": "#",
                "hasurl": true,
                "badge": "locked",
                "badgelabel": "Restricted",
                "islocked": true,
                "istimed": false,
                "hasbadge": true,
                "reason": "Not available unless you complete Forum introduction",
                "hasreason": true,
                "duedate": 0,
                "hasduedate": false,
                "duedateformatted": "",
                "dimmed": false,
                "hiddenlabel": ""
            }
        ]
    }
}}
{{#hascards}}
    <div class="sc-trail">
        {{#cards}}
            {{> format_smartcards/local/cm_button }}
        {{/cards}}
    </div>
{{/hascards}}
