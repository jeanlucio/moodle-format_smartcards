{{!
    @template format_smartcards/local/section_card_button

    Single section card/button, for navstyle = 'sectioncards'. Same visual language as
    cm_button.mustache (icon circle + title), but always a button: tapping it opens a
    full-screen modal (amd/src/section_modal.js) with either the section's own nested
    activity grid, or — when islocked — the restriction reason, pulled from the paired
    hidden container this button's sibling renders (see content.mustache).

    Example context (json):
    {
        "id": 12,
        "name": "Topic 1",
        "islocked": false,
        "hasbadge": false,
        "badgelabel": "",
        "iconurl": "#",
        "isemoji": false,
        "emoji": "",
        "iscustomicon": true,
        "customiconurl": "#",
        "hasiconstyle": true,
        "iconstyle": "background-color: #1565c0",
        "isbsicon": true,
        "hasiconcolorstyle": true,
        "iconcolorstyle": "background-color: #ffffff",
        "hastitlestyle": false,
        "titlestyle": "",
        "hasprogress": true,
        "progresslabel": "Progress: 2 / 5",
        "hascompletionbadge": true,
        "iscompletionpending": true,
        "iscompletioncomplete": false,
        "completionbadgelabel": "Pending",
        "hascards": true
    }
}}
<button
    type="button"
    class="sc-card sc-section-card{{#islocked}} sc-card-dimmed{{/islocked}}"
    data-region="smartcards-section-card"
    data-sectionid="{{id}}"
    data-name="{{name}}"
    data-islocked="{{#islocked}}1{{/islocked}}{{^islocked}}0{{/islocked}}"
    aria-label="{{name}}{{#hasbadge}} — {{badgelabel}}{{/hasbadge}}"
>
    <span class="sc-card-icon" aria-hidden="true"{{#hasiconstyle}} style="{{iconstyle}}"{{/hasiconstyle}}>
        {{> format_smartcards/local/cm_icon }}
        <span class="sc-card-badgeicon">{{#islocked}}🔒{{/islocked}}</span>
        {{#hascompletionbadge}}
        <span class="sc-card-completionicon">{{#iscompletioncomplete}}✅{{/iscompletioncomplete}}{{^iscompletioncomplete}}⚪{{/iscompletioncomplete}}</span>
        {{/hascompletionbadge}}
    </span>
    <span class="sc-card-title"{{#hastitlestyle}} style="{{titlestyle}}"{{/hastitlestyle}}>{{name}}</span>
    {{#hasprogress}}<span class="sc-progress-label">{{progresslabel}}</span>{{/hasprogress}}
</button>
