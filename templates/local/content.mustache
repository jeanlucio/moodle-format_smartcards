{{!
    @template format_smartcards/local/content

    Main grid container for the SmartCards course format. Each section is
    rendered as a heading followed by a grid of activity cards.

    Example context (json):
    {
        "uniqid": "sc63a1b2",
        "hassections": true,
        "canedit": false,
        "editmodeactive": false,
        "sections": [
            {
                "id": 10,
                "num": 1,
                "name": "Topic 1",
                "issection0": false,
                "hascards": true,
                "cards": [
                    {
                        "cmid": 5,
                        "name": "Quiz 1",
                        "iconurl": "#",
                        "modtypelabel": "Quiz",
                        "url": "#",
                        "hasurl": true,
                        "badge": "locked",
                        "badgelabel": "Restricted",
                        "islocked": true,
                        "istimed": false,
                        "hasbadge": true,
                        "reason": "Not available unless you complete Forum introduction",
                        "hasreason": true,
                        "duedate": 0,
                        "hasduedate": false,
                        "duedateformatted": "",
                        "dimmed": false,
                        "hiddenlabel": ""
                    }
                ]
            }
        ]
    }
}}
<div id="{{uniqid}}" class="sc-course" data-region="smartcards-content">
    {{#hassections}}
        {{#sections}}
            <section class="sc-section" aria-labelledby="sc-section-title-{{id}}">
                <h3 class="sc-section-title" id="sc-section-title-{{id}}">{{name}}</h3>
                {{#hascards}}
                    <div class="sc-grid">
                        {{#cards}}
                            {{> format_smartcards/local/cm_button }}
                        {{/cards}}
                    </div>
                {{/hascards}}
            </section>
        {{/sections}}
    {{/hassections}}
</div>
