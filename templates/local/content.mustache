{{!
    @template format_smartcards/local/content

    Main grid container for the SmartCards course format. Section 0 (General) always
    renders plain, outside any special navigation. Sections 1+ render one of four ways
    depending on navstyle: plain (default/sticky — identical markup, sticky only differs
    by a CSS class making each section heading position: sticky while scrolling),
    collapsible (accordion), or as Bootstrap tabs (tabs) — never more than one of
    isaccordion/istabs/issticky is true at once.

    Example context (json):
    {
        "uniqid": "sc63a1b2",
        "hassections": true,
        "canedit": false,
        "editmodeactive": false,
        "cardsizeclass": "sc-size-small",
        "noframeclass": "",
        "isaccordion": true,
        "istabs": false,
        "issticky": false,
        "sections": [
            {
                "id": 10,
                "num": 1,
                "name": "Topic 1",
                "issection0": false,
                "hascards": true,
                "iscollapsible": true,
                "isopen": true,
                "isactivetab": false,
                "hasprogress": true,
                "progresslabel": "Progress: 2 / 5",
                "cards": [
                    {
                        "cmid": 5,
                        "name": "Quiz 1",
                        "iconurl": "#",
                        "modtypelabel": "Quiz",
                        "url": "#",
                        "hasurl": true,
                        "badge": "locked",
                        "badgelabel": "Restricted",
                        "islocked": true,
                        "istimed": false,
                        "hasbadge": true,
                        "reason": "Not available unless you complete Forum introduction",
                        "hasreason": true,
                        "duedate": 0,
                        "hasduedate": false,
                        "duedateformatted": "",
                        "dimmed": false,
                        "hiddenlabel": ""
                    }
                ]
            }
        ]
    }
}}
<div
    id="{{uniqid}}"
    class="sc-course {{cardsizeclass}} {{noframeclass}} {{#issticky}}sc-sticky{{/issticky}}"
    data-region="smartcards-content"
>
    {{#hassections}}
        {{#sections}}
            {{#issection0}}
                <section class="sc-section" aria-labelledby="sc-section-title-{{id}}">
                    <h3 class="sc-section-title" id="sc-section-title-{{id}}">{{name}}</h3>
                    {{> format_smartcards/local/cm_grid }}
                </section>
            {{/issection0}}
        {{/sections}}

        {{#istabs}}
            <ul class="nav nav-tabs sc-tabs" role="tablist">
                {{#sections}}
                    {{^issection0}}
                    <li class="nav-item" role="presentation">
                        <button
                            type="button"
                            class="nav-link {{#isactivetab}}active{{/isactivetab}}"
                            id="sc-tab-{{id}}"
                            data-toggle="tab"
                            data-bs-toggle="tab"
                            data-target="#sc-tab-pane-{{id}}"
                            data-bs-target="#sc-tab-pane-{{id}}"
                            role="tab"
                            aria-controls="sc-tab-pane-{{id}}"
                            aria-selected="{{#isactivetab}}true{{/isactivetab}}{{^isactivetab}}false{{/isactivetab}}"
                        >
                            <span class="sc-tabs-name">{{name}}</span>
                            {{#hasprogress}}<span class="sc-tabs-progress">{{progresslabel}}</span>{{/hasprogress}}
                        </button>
                    </li>
                    {{/issection0}}
                {{/sections}}
            </ul>
            <div class="tab-content">
                {{#sections}}
                    {{^issection0}}
                    <div
                        class="tab-pane fade {{#isactivetab}}show active{{/isactivetab}}"
                        id="sc-tab-pane-{{id}}"
                        role="tabpanel"
                        aria-labelledby="sc-tab-{{id}}"
                    >
                        {{> format_smartcards/local/cm_grid }}
                    </div>
                    {{/issection0}}
                {{/sections}}
            </div>
        {{/istabs}}

        {{^istabs}}
            {{#sections}}
                {{^issection0}}
                <section class="sc-section" aria-labelledby="sc-section-title-{{id}}">
                    {{#iscollapsible}}
                    <h3 class="sc-section-title sc-accordion-title" id="sc-section-title-{{id}}">
                        <button
                            type="button"
                            class="sc-accordion-toggle {{^isopen}}collapsed{{/isopen}}"
                            data-toggle="collapse"
                            data-bs-toggle="collapse"
                            data-target="#sc-accordion-body-{{id}}"
                            data-bs-target="#sc-accordion-body-{{id}}"
                            aria-expanded="{{#isopen}}true{{/isopen}}{{^isopen}}false{{/isopen}}"
                            aria-controls="sc-accordion-body-{{id}}"
                        >
                            <span class="sc-accordion-chevron-collapsed" aria-hidden="true">
                                {{#pix}} t/collapsedchevron, core {{/pix}}
                            </span>
                            <span class="sc-accordion-chevron-expanded" aria-hidden="true">
                                {{#pix}} t/expandedchevron, core {{/pix}}
                            </span>
                            <span class="sc-accordion-name">{{name}}</span>
                            {{#hasprogress}}
                            <span class="sc-accordion-progress">{{progresslabel}}</span>
                            {{/hasprogress}}
                        </button>
                    </h3>
                    {{/iscollapsible}}
                    {{^iscollapsible}}
                    <h3 class="sc-section-title" id="sc-section-title-{{id}}">{{name}}</h3>
                    {{/iscollapsible}}

                    <div{{#iscollapsible}}
                        id="sc-accordion-body-{{id}}"
                        class="collapse {{#isopen}}show{{/isopen}}"
                        data-region="smartcards-accordion-body"
                        data-sectionid="{{id}}"
                    {{/iscollapsible}}>
                        {{> format_smartcards/local/cm_grid }}
                    </div>
                </section>
                {{/issection0}}
            {{/sections}}
        {{/istabs}}
    {{/hassections}}
</div>
