{{!
    @template format_smartcards/local/content

    Main grid container for the SmartCards course format. Each section is
    rendered as a heading followed by a grid of activity cards.

    Example context (json):
    {
        "uniqid": "sc63a1b2",
        "hassections": true,
        "canedit": false,
        "editmodeactive": false,
        "cardsizeclass": "sc-size-small",
        "noframeclass": "",
        "isaccordion": true,
        "sections": [
            {
                "id": 10,
                "num": 1,
                "name": "Topic 1",
                "issection0": false,
                "hascards": true,
                "iscollapsible": true,
                "isopen": true,
                "hasprogress": true,
                "progresslabel": "Progress: 2 / 5",
                "cards": [
                    {
                        "cmid": 5,
                        "name": "Quiz 1",
                        "iconurl": "#",
                        "modtypelabel": "Quiz",
                        "url": "#",
                        "hasurl": true,
                        "badge": "locked",
                        "badgelabel": "Restricted",
                        "islocked": true,
                        "istimed": false,
                        "hasbadge": true,
                        "reason": "Not available unless you complete Forum introduction",
                        "hasreason": true,
                        "duedate": 0,
                        "hasduedate": false,
                        "duedateformatted": "",
                        "dimmed": false,
                        "hiddenlabel": ""
                    }
                ]
            }
        ]
    }
}}
<div id="{{uniqid}}" class="sc-course {{cardsizeclass}} {{noframeclass}}" data-region="smartcards-content">
    {{#hassections}}
        {{#sections}}
            <section class="sc-section" aria-labelledby="sc-section-title-{{id}}">
                {{#iscollapsible}}
                <h3 class="sc-section-title sc-accordion-title" id="sc-section-title-{{id}}">
                    <button
                        type="button"
                        class="sc-accordion-toggle {{^isopen}}collapsed{{/isopen}}"
                        data-toggle="collapse"
                        data-bs-toggle="collapse"
                        data-target="#sc-accordion-body-{{id}}"
                        data-bs-target="#sc-accordion-body-{{id}}"
                        aria-expanded="{{#isopen}}true{{/isopen}}{{^isopen}}false{{/isopen}}"
                        aria-controls="sc-accordion-body-{{id}}"
                    >
                        <span class="sc-accordion-chevron-collapsed" aria-hidden="true">
                            {{#pix}} t/collapsedchevron, core {{/pix}}
                        </span>
                        <span class="sc-accordion-chevron-expanded" aria-hidden="true">
                            {{#pix}} t/expandedchevron, core {{/pix}}
                        </span>
                        <span class="sc-accordion-name">{{name}}</span>
                        {{#hasprogress}}
                        <span class="sc-accordion-progress">{{progresslabel}}</span>
                        {{/hasprogress}}
                    </button>
                </h3>
                {{/iscollapsible}}
                {{^iscollapsible}}
                <h3 class="sc-section-title" id="sc-section-title-{{id}}">{{name}}</h3>
                {{/iscollapsible}}

                <div{{#iscollapsible}}
                    id="sc-accordion-body-{{id}}"
                    class="collapse {{#isopen}}show{{/isopen}}"
                    data-region="smartcards-accordion-body"
                    data-sectionid="{{id}}"
                {{/iscollapsible}}>
                    {{#hascards}}
                        <div class="sc-grid">
                            {{#cards}}
                                {{> format_smartcards/local/cm_button }}
                            {{/cards}}
                        </div>
                    {{/hascards}}
                </div>
            </section>
        {{/sections}}
    {{/hassections}}
</div>
