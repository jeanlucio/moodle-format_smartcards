{{!
    @template format_smartcards/local/cm_grid

    One section's card grid, shared by every navstyle (plain section, accordion body,
    tab pane) so the "no cards, render nothing" rule never drifts between them.

    Example context (json):
    {
        "hascards": true,
        "cards": [
            {
                "cmid": 5,
                "name": "Quiz 1",
                "iconurl": "#",
                "modtypelabel": "Quiz",
                "url": "#",
                "hasurl": true,
                "badge": "locked",
                "badgelabel": "Restricted",
                "islocked": true,
                "istimed": false,
                "hasbadge": true,
                "reason": "Not available unless you complete Forum introduction",
                "hasreason": true,
                "duedate": 0,
                "hasduedate": false,
                "duedateformatted": "",
                "dimmed": false,
                "hiddenlabel": ""
            }
        ]
    }
}}
{{#hascards}}
    <div class="sc-grid">
        {{#cards}}
            {{> format_smartcards/local/cm_button }}
        {{/cards}}
    </div>
{{/hascards}}
